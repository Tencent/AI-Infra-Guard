# =============================================================================
# 全局默认环境变量（会被 .env.<mode> 中的同名值覆盖）
# =============================================================================

# 后端 API base，前端通过 fetch('/api/xxx') 相对访问
VITE_API_BASE_URL=/

# 本地开发时 vite dev server 的代理目标（当访问 /api、/llm 时转发到此地址）
VITE_DEV_PROXY_TARGET=http://localhost:8088
